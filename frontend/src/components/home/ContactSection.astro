---
import { copy, type Locale } from "../../lib/i18n";
import { socialLinks } from "../../lib/siteContent";
import Button from "../ui/Button.astro";
import Section from "../ui/Section.astro";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = copy[locale];
const visibleSocialLinks = socialLinks.filter((link) => link.href.trim().length > 0);
---

<Section
  id="contact"
  eyebrow={t.contact.eyebrow}
  title={t.contact.title}
  description={t.contact.description}
  class="border-t border-border"
>
  <div class="grid gap-10 lg:grid-cols-[minmax(0,0.9fr)_minmax(320px,1fr)]">
    <div class="home-reveal border-t border-border pt-6">
      <p class="font-mono text-xs uppercase tracking-[0.18em] text-primary">
        {t.contact.linksLabel}
      </p>
      <div class="mt-5 flex flex-wrap gap-3">
        {
          visibleSocialLinks.map((link) => (
            <a
              href={link.href}
              target="_blank"
              rel="noreferrer"
              class="rounded-full border border-border bg-surface px-4 py-2 text-sm font-semibold text-ink transition duration-200 hover:border-primary/70 hover:text-primary-strong focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-primary-strong"
            >
              {link.label}
            </a>
          ))
        }
      </div>
    </div>

    <form
      class="home-reveal rounded-xl border border-border bg-surface p-5 sm:p-6"
      data-contact-form
      novalidate
    >
      <h3 class="text-lg font-semibold text-ink">{t.contact.formTitle}</h3>

      <div class="mt-5 grid gap-4">
        <div>
          <label class="text-sm font-medium text-ink" for="contact-name">
            {t.contact.nameLabel}
          </label>
          <input
            id="contact-name"
            name="name"
            type="text"
            maxlength="120"
            required
            placeholder={t.contact.namePlaceholder}
            class="mt-2 min-h-11 w-full rounded-lg border border-border bg-bg px-3 py-2 text-sm text-ink outline-none transition placeholder:text-subtle focus:border-primary focus:ring-2 focus:ring-primary/25"
          />
        </div>

        <div>
          <label class="text-sm font-medium text-ink" for="contact-email">
            {t.contact.emailLabel}
          </label>
          <input
            id="contact-email"
            name="email"
            type="email"
            maxlength="254"
            required
            placeholder={t.contact.emailPlaceholder}
            class="mt-2 min-h-11 w-full rounded-lg border border-border bg-bg px-3 py-2 text-sm text-ink outline-none transition placeholder:text-subtle focus:border-primary focus:ring-2 focus:ring-primary/25"
          />
        </div>

        <div>
          <label class="text-sm font-medium text-ink" for="contact-message">
            {t.contact.messageLabel}
          </label>
          <textarea
            id="contact-message"
            name="message"
            maxlength="3000"
            required
            rows="5"
            placeholder={t.contact.messagePlaceholder}
            class="mt-2 w-full resize-y rounded-lg border border-border bg-bg px-3 py-2 text-sm text-ink outline-none transition placeholder:text-subtle focus:border-primary focus:ring-2 focus:ring-primary/25"
          ></textarea>
        </div>

        <div class="hidden" aria-hidden="true">
          <label for="contact-company">{t.contact.companyLabel}</label>
          <input
            id="contact-company"
            name="company"
            type="text"
            tabindex="-1"
            autocomplete="off"
          />
        </div>
      </div>

      <div class="mt-5 flex flex-wrap items-center gap-4">
        <Button type="submit" variant="primary">
          <span data-submit-label>{t.contact.submit}</span>
        </Button>
        <p
          class="min-h-6 text-sm text-muted"
          data-contact-status
          data-success={t.contact.success}
          data-error={t.contact.error}
          data-validation-error={t.contact.validationError}
          data-submitting={t.contact.submitting}
          aria-live="polite"
        ></p>
      </div>
    </form>
  </div>
</Section>

<script>
  const form = document.querySelector<HTMLFormElement>("[data-contact-form]");

  if (form) {
    const status = form.querySelector<HTMLElement>("[data-contact-status]");
    const submitLabel = form.querySelector<HTMLElement>("[data-submit-label]");
    const submitButton = form.querySelector<HTMLButtonElement>("button[type='submit']");
    const initialLabel = submitLabel?.textContent ?? "";

    form.addEventListener("submit", async (event) => {
      event.preventDefault();

      if (!form.checkValidity()) {
        form.reportValidity();
        if (status) {
          status.textContent = status.dataset.validationError ?? "";
          status.className = "min-h-6 text-sm text-danger";
        }
        return;
      }

      const formData = new FormData(form);

      submitButton?.setAttribute("disabled", "true");
      if (submitLabel && status) {
        submitLabel.textContent = status.dataset.submitting ?? initialLabel;
        status.textContent = "";
        status.className = "min-h-6 text-sm text-muted";
      }

      try {
        const response = await fetch("/api/contact", {
          method: "POST",
          body: formData
        });
        const body = (await response.json().catch(() => ({}))) as { ok?: boolean };

        if (!response.ok || !body.ok) {
          throw new Error("Contact request failed.");
        }

        form.reset();
        if (status) {
          status.textContent = status.dataset.success ?? "";
          status.className = "min-h-6 text-sm text-primary-strong";
        }
      } catch {
        if (status) {
          status.textContent = status.dataset.error ?? "";
          status.className = "min-h-6 text-sm text-danger";
        }
      } finally {
        submitButton?.removeAttribute("disabled");
        if (submitLabel) {
          submitLabel.textContent = initialLabel;
        }
      }
    });
  }
</script>
