{
  "name": "portfolio-data-science-backend",
  "version": "0.1.0",
  "description": "Backend for a Data Science portfolio powered by GitHub Markdown project metadata.",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "migrate": "tsx src/db/migrate.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "gray-matter": "^4.0.3",
    "markdown-it": "^14.1.0",
    "pg": "^8.13.1",
    "sanitize-html": "^2.14.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "@types/sanitize-html": "^2.13.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.2.6"
  },
  "engines": {
    "node": ">=20.11.0"
  }
}
