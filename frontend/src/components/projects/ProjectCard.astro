---
import { formatDate } from "../../lib/formatDate";
import { copy, interpolate, type Locale, withLocale } from "../../lib/i18n";
import type { Project } from "../../lib/types";
import Badge from "../ui/Badge.astro";

interface Props {
  project: Project;
  locale: Locale;
}

const { project, locale } = Astro.props;
const t = copy[locale];
const links: Array<{ label: string; href: string | null | undefined }> = [
  { label: t.projects.repo, href: project.repoUrl },
  { label: t.projects.demo, href: project.demoUrl },
  { label: t.projects.dashboard, href: project.dashboardUrl ?? null }
].flatMap((link) =>
  link.href ? [{ label: link.label, href: link.href }] : []
);
const projectHref = withLocale(`/projects/${project.slug}`, locale);
---

<article class="group overflow-hidden rounded-xl border border-border bg-surface transition duration-200 hover:-translate-y-0.5 hover:border-primary/60">
  {
    project.coverImage ? (
      <a href={projectHref} class="block border-b border-border">
        <img
          src={project.coverImage}
          alt={interpolate(t.projects.coverAlt, { title: project.title })}
          loading="lazy"
          class="aspect-[16/9] w-full object-cover grayscale transition duration-300 group-hover:grayscale-0"
        />
      </a>
    ) : null
  }
  <div class="p-5">
    <div class="flex flex-wrap items-center gap-2">
      {project.featured ? <Badge tone="primary">{t.projects.featured}</Badge> : null}
      <span class="font-mono text-xs text-subtle">{formatDate(project.date, locale)}</span>
    </div>

    <h3 class="mt-4 text-xl font-semibold leading-snug text-ink">
      <a href={projectHref} class="transition hover:text-primary-strong">
        {project.title}
      </a>
    </h3>

    {
      project.summary ? (
        <p class="mt-3 line-clamp-3 text-sm leading-6 text-muted">
          {project.summary}
        </p>
      ) : null
    }

    {
      project.tools.length > 0 ? (
        <div class="mt-5 flex flex-wrap gap-2">
          {project.tools.slice(0, 6).map((tool) => (
            <Badge tone="muted">{tool}</Badge>
          ))}
        </div>
      ) : null
    }

    <div class="mt-5 flex flex-wrap gap-4 text-sm font-medium text-muted">
      <a class="transition hover:text-primary-strong" href={projectHref}>
        {t.projects.readCaseStudy}
      </a>
      {
        links.map((link) => (
          <a
            class="transition hover:text-primary-strong"
            href={link.href}
            target="_blank"
            rel="noreferrer"
          >
            {link.label}
          </a>
        ))
      }
    </div>
  </div>
</article>
