---
import { copy, type Locale } from "../../lib/i18n";
import EmptyState from "../ui/EmptyState.astro";

interface Props {
  html?: string | null;
  locale: Locale;
}

const { html, locale } = Astro.props;
const t = copy[locale];
const hasContent = typeof html === "string" && html.trim().length > 0;
---

{
  hasContent ? (
    <div class="prose-content" set:html={html} />
  ) : (
    <EmptyState
      title={t.states.noContentTitle}
      message={t.states.noContentMessage}
    />
  )
}

<style>
  .prose-content {
    max-width: 76ch;
    color: var(--color-muted);
    font-size: 1rem;
    line-height: 1.85;
    text-wrap: pretty;
  }

  .prose-content :global(*) {
    max-width: 100%;
  }

  .prose-content :global(h1),
  .prose-content :global(h2),
  .prose-content :global(h3),
  .prose-content :global(h4) {
    color: var(--color-ink);
    font-weight: 650;
    line-height: 1.2;
    text-wrap: balance;
  }

  .prose-content :global(h1) {
    margin: 0 0 1.25rem;
    font-size: clamp(2.25rem, 5vw, 4.5rem);
    letter-spacing: -0.03em;
  }

  .prose-content :global(h2) {
    margin: 3rem 0 1rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
    font-size: clamp(1.75rem, 3vw, 2.5rem);
  }

  .prose-content :global(h3) {
    margin: 2rem 0 0.75rem;
    font-size: 1.35rem;
  }

  .prose-content :global(h4) {
    margin: 1.5rem 0 0.5rem;
    font-size: 1.1rem;
  }

  .prose-content :global(p),
  .prose-content :global(ul),
  .prose-content :global(ol),
  .prose-content :global(blockquote),
  .prose-content :global(pre),
  .prose-content :global(table),
  .prose-content :global(figure) {
    margin: 1.15rem 0;
  }

  .prose-content :global(a) {
    color: var(--color-primary-strong);
    text-decoration: underline;
    text-decoration-color: oklch(0.720 0.095 110 / 0.45);
    text-underline-offset: 0.22em;
  }

  .prose-content :global(a:hover) {
    text-decoration-color: var(--color-primary-strong);
  }

  .prose-content :global(strong) {
    color: var(--color-ink);
    font-weight: 700;
  }

  .prose-content :global(ul),
  .prose-content :global(ol) {
    padding-left: 1.35rem;
  }

  .prose-content :global(li) {
    margin: 0.45rem 0;
    padding-left: 0.25rem;
  }

  .prose-content :global(blockquote) {
    border-left: 1px solid var(--color-primary);
    padding-left: 1rem;
    color: var(--color-ink);
  }

  .prose-content :global(code) {
    border: 1px solid var(--color-border);
    border-radius: 0.4rem;
    background: var(--color-surface);
    color: var(--color-ink);
    font-family: var(--font-mono);
    font-size: 0.9em;
    padding: 0.1rem 0.35rem;
  }

  .prose-content :global(pre) {
    overflow-x: auto;
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    background: var(--color-surface);
    padding: 1rem;
  }

  .prose-content :global(pre code) {
    border: 0;
    background: transparent;
    padding: 0;
  }

  .prose-content :global(img) {
    margin: 2rem 0;
    border-radius: 0.75rem;
    border: 1px solid var(--color-border);
  }

  .prose-content :global(table) {
    display: block;
    width: 100%;
    overflow-x: auto;
    border-collapse: collapse;
    font-size: 0.95rem;
  }

  .prose-content :global(th),
  .prose-content :global(td) {
    border-bottom: 1px solid var(--color-border);
    padding: 0.85rem;
    text-align: left;
    vertical-align: top;
  }

  .prose-content :global(th) {
    color: var(--color-ink);
    font-weight: 650;
  }
</style>
