---
export const prerender = false;

import BaseLayout from "../../../components/layout/BaseLayout.astro";
import ProjectGrid from "../../../components/projects/ProjectGrid.astro";
import Badge from "../../../components/ui/Badge.astro";
import EmptyState from "../../../components/ui/EmptyState.astro";
import ErrorState from "../../../components/ui/ErrorState.astro";
import { getProjects } from "../../../lib/api";
import { compareProjectsByDate } from "../../../lib/formatDate";
import { copy, isLocale, type Locale, withLocale } from "../../../lib/i18n";
import type { Project } from "../../../lib/types";

const localeParam = Astro.params.locale;

if (!isLocale(localeParam)) {
  return Astro.redirect("/en/projects", 302);
}

const locale: Locale = localeParam;
let projects: Project[] = [];
let hadError = false;

try {
  projects = await getProjects(locale);
} catch {
  hadError = true;
  Astro.response.status = 502;
}

const selectedTool = Astro.url.searchParams.get("tool")?.trim() ?? "";
const sortedProjects = [...projects].sort(compareProjectsByDate);
const tools = Array.from(
  new Set(sortedProjects.flatMap((project) => project.tools))
).sort((first, second) => first.localeCompare(second));
const filteredProjects = selectedTool
  ? sortedProjects.filter((project) => project.tools.includes(selectedTool))
  : sortedProjects;
const t = copy[locale];
---

<BaseLayout
  title={t.projects.pageTitle}
  description={t.projects.pageDescription}
  locale={locale}
>
  <section class="mx-auto w-full max-w-6xl px-5 py-12 sm:px-6 sm:py-16 lg:px-8">
    <div class="max-w-3xl">
      <p class="font-mono text-xs uppercase tracking-[0.18em] text-primary">
        {t.projects.eyebrow}
      </p>
      <h1 class="mt-4 text-balance text-4xl font-semibold leading-tight text-ink sm:text-5xl">
        {t.projects.headline}
      </h1>
      <p class="mt-5 text-lg leading-8 text-muted">
        {t.projects.description}
      </p>
    </div>

    {
      hadError ? (
        <div class="mt-10">
          <ErrorState locale={locale} />
        </div>
      ) : (
        <>
          {tools.length > 0 ? (
            <div class="mt-10 flex flex-wrap gap-2" aria-label={t.projects.filterLabel}>
              <a href={withLocale("/projects", locale)}>
                <Badge tone={selectedTool ? "muted" : "primary"}>{t.projects.all}</Badge>
              </a>
              {tools.map((tool) => (
                <a href={`${withLocale("/projects", locale)}?tool=${encodeURIComponent(tool)}`}>
                  <Badge tone={selectedTool === tool ? "primary" : "muted"}>
                    {tool}
                  </Badge>
                </a>
              ))}
            </div>
          ) : null}

          <div class="mt-10">
            {filteredProjects.length > 0 ? (
              <ProjectGrid projects={filteredProjects} locale={locale} />
            ) : (
              <EmptyState
                title={t.projects.emptyTitle}
                message={t.projects.emptyMessage}
              />
            )}
          </div>
        </>
      )
    }
  </section>
</BaseLayout>
